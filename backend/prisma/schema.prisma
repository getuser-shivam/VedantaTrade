generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model ChartOfAccounts {
  account_id                                                                   Int              @id(map: "PK__ChartOfA__46A222CD9C56D764") @default(autoincrement())
  account_name                                                                 String           @unique(map: "UQ__ChartOfA__6894C54A3949669C") @db.NVarChar(255)
  account_type                                                                 String           @db.NVarChar(50)
  account_sub_type                                                             String?          @db.NVarChar(100)
  description                                                                  String?          @db.NVarChar(Max)
  Expenses                                                                     Expenses[]
  InventoryItems_InventoryItems_cost_of_goods_sold_account_idToChartOfAccounts InventoryItems[] @relation("InventoryItems_cost_of_goods_sold_account_idToChartOfAccounts")
  InventoryItems_InventoryItems_inventory_asset_account_idToChartOfAccounts    InventoryItems[] @relation("InventoryItems_inventory_asset_account_idToChartOfAccounts")
  InventoryItems_InventoryItems_revenue_account_idToChartOfAccounts            InventoryItems[] @relation("InventoryItems_revenue_account_idToChartOfAccounts")
  JournalItems                                                                 JournalItems[]
}

model Currencies {
  currency_id                                              Int              @id(map: "PK__Currenci__C7F543D31BC3DFE4") @default(autoincrement())
  currency_code                                            String           @unique(map: "UQ__Currenci__6008D0BA9462511D") @db.NVarChar(10)
  currency_name                                            String           @db.NVarChar(50)
  ExchangeRates_ExchangeRates_from_currency_idToCurrencies ExchangeRates[]  @relation("ExchangeRates_from_currency_idToCurrencies")
  ExchangeRates_ExchangeRates_to_currency_idToCurrencies   ExchangeRates[]  @relation("ExchangeRates_to_currency_idToCurrencies")
  Expenses                                                 Expenses[]
  PurchaseOrders                                           PurchaseOrders[]
  SalesOrders                                              SalesOrders[]
  Vendors                                                  Vendors[]
}

model Customers {
  customer_id    Int           @id(map: "PK__Customer__CD65CB8551C9817B") @default(autoincrement())
  customer_name  String        @db.NVarChar(255)
  contact_person String?       @db.NVarChar(255)
  email          String?       @db.NVarChar(255)
  phone          String?       @db.NVarChar(50)
  address        String?       @db.NVarChar(Max)
  SalesOrders    SalesOrders[]
}

model ExchangeRates {
  exchange_rate_id                                      Int        @id(map: "PK__Exchange__0638B3CD5DFF91BD") @default(autoincrement())
  from_currency_id                                      Int
  to_currency_id                                        Int
  rate                                                  Float
  effective_date                                        String     @db.NVarChar(20)
  Currencies_ExchangeRates_from_currency_idToCurrencies Currencies @relation("ExchangeRates_from_currency_idToCurrencies", fields: [from_currency_id], references: [currency_id], onUpdate: NoAction, map: "FK__ExchangeR__from___164452B1")
  Currencies_ExchangeRates_to_currency_idToCurrencies   Currencies @relation("ExchangeRates_to_currency_idToCurrencies", fields: [to_currency_id], references: [currency_id], onUpdate: NoAction, map: "FK__ExchangeR__to_cu__173876EA")
}

model Expenses {
  expense_id       Int             @id(map: "PK__Expenses__404B6A6BD0EABFA9") @default(autoincrement())
  expense_date     String          @db.NVarChar(20)
  description      String?         @db.NVarChar(Max)
  amount           Float
  currency_id      Int
  exchange_rate    Float?
  expense_category String?         @db.NVarChar(100)
  vendor_id        Int?
  account_id       Int
  ChartOfAccounts  ChartOfAccounts @relation(fields: [account_id], references: [account_id], onUpdate: NoAction, map: "FK__Expenses__accoun__412EB0B6")
  Currencies       Currencies      @relation(fields: [currency_id], references: [currency_id], onUpdate: NoAction, map: "FK__Expenses__curren__3F466844")
  Vendors          Vendors?        @relation(fields: [vendor_id], references: [vendor_id], onDelete: NoAction, onUpdate: NoAction, map: "FK__Expenses__vendor__403A8C7D")
}

model InventoryBatches {
  batch_id           Int               @id(map: "PK__Inventor__DBFC04310A1F90C2") @default(autoincrement())
  item_id            Int
  batch_number       String            @db.NVarChar(100)
  manufacturing_date String?           @db.NVarChar(20)
  expiry_date        String?           @db.NVarChar(20)
  quantity           Int
  unit_cost          Float?
  InventoryItems     InventoryItems    @relation(fields: [item_id], references: [item_id], onUpdate: NoAction, map: "FK__Inventory__item___2C3393D0")
  SalesOrderItems    SalesOrderItems[]
}

model InventoryItems {
  item_id                                                                       Int                  @id(map: "PK__Inventor__52020FDD0EF6F8F0") @default(autoincrement())
  item_name                                                                     String               @unique(map: "UQ__Inventor__ACA52A97B0811600") @db.NVarChar(255)
  description                                                                   String?              @db.NVarChar(Max)
  unit_of_measure                                                               String?              @db.NVarChar(50)
  cost_of_goods_sold_account_id                                                 Int?
  inventory_asset_account_id                                                    Int?
  revenue_account_id                                                            Int?
  // Pharma Extensions
  generic_name          String?  @db.NVarChar(255)
  sku                   String?  @unique @db.NVarChar(100)
  manufacturer          String?  @db.NVarChar(255)
  composition           String?  @db.NVarChar(Max)
  pack_size             String?  @db.NVarChar(100)
  mrp                   Float?
  ptr                   Float?
  pts                   Float?
  gst_percent           Float?   @default(12)
  stock_quantity        Int?     @default(0)
  requires_prescription Boolean? @default(false)
  is_active             Boolean? @default(true)
  image_urls            String?  @db.NVarChar(Max) // JSON or comma-separated

  category_id           Int?
  category              Category? @relation(fields: [category_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  InventoryBatches                                                              InventoryBatches[]
  ChartOfAccounts_InventoryItems_cost_of_goods_sold_account_idToChartOfAccounts ChartOfAccounts?     @relation("InventoryItems_cost_of_goods_sold_account_idToChartOfAccounts", fields: [cost_of_goods_sold_account_id], references: [account_id], onDelete: NoAction, onUpdate: NoAction, map: "FK__Inventory__cost___276EDEB3")
  ChartOfAccounts_InventoryItems_inventory_asset_account_idToChartOfAccounts    ChartOfAccounts?     @relation("InventoryItems_inventory_asset_account_idToChartOfAccounts", fields: [inventory_asset_account_id], references: [account_id], onDelete: NoAction, onUpdate: NoAction, map: "FK__Inventory__inven__286302EC")
  ChartOfAccounts_InventoryItems_revenue_account_idToChartOfAccounts            ChartOfAccounts?     @relation("InventoryItems_revenue_account_idToChartOfAccounts", fields: [revenue_account_id], references: [account_id], onDelete: NoAction, onUpdate: NoAction, map: "FK__Inventory__reven__29572725")
  PurchaseOrderItems                                                            PurchaseOrderItems[]
  SalesOrderItems                                                               SalesOrderItems[]

  sampleDistributions SampleDistribution[]
  mrTargetItems       MrTargetItem[]
}

model JournalEntries {
  journal_id       Int            @id(map: "PK__JournalE__9894D298791DF8E7") @default(autoincrement())
  entry_date       String         @db.NVarChar(20)
  description      String?        @db.NVarChar(Max)
  transaction_type String?        @db.NVarChar(50)
  reference_number String?        @db.NVarChar(100)
  fiscal_year      String         @db.NVarChar(20)
  JournalItems     JournalItems[]
}

model JournalItems {
  item_id         Int             @id(map: "PK__JournalI__52020FDD29ADD35C") @default(autoincrement())
  journal_id      Int
  account_id      Int
  debit           Float?          @default(0, map: "DF__JournalIt__debit__1BFD2C07")
  credit          Float?          @default(0, map: "DF__JournalIt__credi__1CF15040")
  ChartOfAccounts ChartOfAccounts @relation(fields: [account_id], references: [account_id], onUpdate: NoAction, map: "FK__JournalIt__accou__1ED998B2")
  JournalEntries  JournalEntries  @relation(fields: [journal_id], references: [journal_id], onUpdate: NoAction, map: "FK__JournalIt__journ__1DE57479")
}

model PurchaseOrderItems {
  po_item_id     Int            @id(map: "PK__Purchase__E2A5830540843926") @default(autoincrement())
  po_id          Int
  item_id        Int
  quantity       Int
  unit_price     Float
  InventoryItems InventoryItems @relation(fields: [item_id], references: [item_id], onUpdate: NoAction, map: "FK__PurchaseO__item___33D4B598")
  PurchaseOrders PurchaseOrders @relation(fields: [po_id], references: [po_id], onUpdate: NoAction, map: "FK__PurchaseO__po_id__32E0915F")
}

model PurchaseOrders {
  po_id              Int                  @id(map: "PK__Purchase__368DA7F0BE6F716A") @default(autoincrement())
  vendor_id          Int
  order_date         String               @db.NVarChar(20)
  delivery_date      String?              @db.NVarChar(20)
  status             String?              @db.NVarChar(50)
  total_amount       Float?
  currency_id        Int
  exchange_rate      Float?
  reference_number   String?              @db.NVarChar(100)
  PurchaseOrderItems PurchaseOrderItems[]
  Currencies         Currencies           @relation(fields: [currency_id], references: [currency_id], onUpdate: NoAction, map: "FK__PurchaseO__curre__300424B4")
  Vendors            Vendors              @relation(fields: [vendor_id], references: [vendor_id], onUpdate: NoAction, map: "FK__PurchaseO__vendo__2F10007B")
}

model SalesOrderItems {
  so_item_id       Int               @id(map: "PK__SalesOrd__14DAD585541DCC73") @default(autoincrement())
  so_id            Int
  item_id          Int
  batch_id         Int?
  quantity         Int
  unit_price       Float
  InventoryBatches InventoryBatches? @relation(fields: [batch_id], references: [batch_id], onDelete: NoAction, onUpdate: NoAction, map: "FK__SalesOrde__batch__3C69FB99")
  InventoryItems   InventoryItems    @relation(fields: [item_id], references: [item_id], onUpdate: NoAction, map: "FK__SalesOrde__item___3B75D760")
  SalesOrders      SalesOrders       @relation(fields: [so_id], references: [so_id], onUpdate: NoAction, map: "FK__SalesOrde__so_id__3A81B327")
}

model SalesOrders {
  so_id                    Int               @id(map: "PK__SalesOrd__56598D5302430A34") @default(autoincrement())
  customer_id              Int
  order_date               String            @db.NVarChar(20)
  delivery_date            String?           @db.NVarChar(20)
  status                   String?           @db.NVarChar(50)
  total_amount             Float?
  currency_id              Int
  inventory_costing_method String?           @db.NVarChar(50)
  reference_number         String?           @db.NVarChar(100)
  SalesOrderItems          SalesOrderItems[]
  Currencies               Currencies        @relation(fields: [currency_id], references: [currency_id], onUpdate: NoAction, map: "FK__SalesOrde__curre__37A5467C")
  Customers                Customers         @relation(fields: [customer_id], references: [customer_id], onUpdate: NoAction, map: "FK__SalesOrde__custo__36B12243")
}

model TaxRates {
  tax_rate_id     Int               @id(map: "PK__TaxRates__4B78B333D6F2F374") @default(autoincrement())
  tax_name        String            @db.NVarChar(100)
  rate            Float
  effective_date  String            @db.NVarChar(20)
  is_active       Boolean?          @default(true, map: "DF__TaxRates__is_act__440B1D61")
  TaxTransactions TaxTransactions[]
}

model TaxTransactions {
  tax_transaction_id Int      @id(map: "PK__TaxTrans__20398E401FF70B49") @default(autoincrement())
  transaction_type   String   @db.NVarChar(50)
  transaction_id     Int
  tax_rate_id        Int
  tax_amount         Float
  tax_type           String   @db.NVarChar(50)
  transaction_date   String   @db.NVarChar(20)
  TaxRates           TaxRates @relation(fields: [tax_rate_id], references: [tax_rate_id], onUpdate: NoAction, map: "FK__TaxTransa__tax_r__46E78A0C")
}

model Users {
  user_id       Int    @id(map: "PK__Users__B9BE370FD2631B25") @default(autoincrement())
  username      String @unique(map: "UQ__Users__F3DBC5721A4BAF8E") @db.NVarChar(255)
  password_hash String @db.NVarChar(Max)
  role          String @default("User", map: "DF__Users__role__4AB81AF0") @db.NVarChar(50)

  // Pharma Extensions
  name          String? @db.NVarChar(255)
  phone         String? @db.NVarChar(50)
  is_active     Boolean @default(true)
  created_at    DateTime @default(now())

  mrProfile    MedicalRep?
  doctorProfile Doctor?
  stockistProfile Stockist?
  retailerProfile Retailer?

  expenses      Expense[]
  mrVisits      MrVisit[]
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.NVarChar(100)
  description String?   @db.NVarChar(Max)
  image_url   String?   @db.NVarChar(Max)
  parent_id   Int?
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now())
  
  parent      Category? @relation("CategoryParent", fields: [parent_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  children    Category[] @relation("CategoryParent")
  products    InventoryItems[]
}

model ScraperJob {
  id           Int      @id @default(autoincrement())
  source       String   @db.NVarChar(50)
  target_type  String   @db.NVarChar(50)
  city         String?  @db.NVarChar(100)
  status       String   @default("PENDING") @db.NVarChar(20)
  leads_found  Int      @default(0)
  created_at   DateTime @default(now())
  leads        ScrapedLead[]
}

model ScrapedLead {
  id          Int      @id @default(autoincrement())
  job_id      Int
  name        String   @db.NVarChar(255)
  phone       String?  @db.NVarChar(50)
  address     String?  @db.NVarChar(Max)
  status      String   @default("RAW") @db.NVarChar(20)
  job         ScraperJob @relation(fields: [job_id], references: [id])
}

model Session {
  id        String   @id @default(cuid()) @db.NVarChar(50)
  user_id   Int
  token     String   @unique @db.NVarChar(500)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model MedicalRep {
  id            Int      @id @default(autoincrement())
  user_id       Int      @unique
  employee_code String   @unique @db.NVarChar(50)
  territory     String   @db.NVarChar(100)
  headquarters  String?  @db.NVarChar(100)
  joining_date  DateTime?
  lat           Float?
  lng           Float?
  user          Users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  visits       MrVisit[]
  targets      MrTarget[]
  samplesGiven SampleDistribution[]
  tourPlans    TourPlan[]
}

model Doctor {
  id              Int     @id @default(autoincrement())
  user_id         Int?    @unique
  name            String  @db.NVarChar(255)
  registration_no String? @unique @db.NVarChar(100)
  specialization  String? @db.NVarChar(255)
  clinic_name     String? @db.NVarChar(255)
  clinic_address  String? @db.NVarChar(Max)
  city            String? @db.NVarChar(100)
  lat             Float?
  lng             Float?
  potential_score Int     @default(0)
  user            Users?  @relation(fields: [user_id], references: [user_id])

  visits          MrVisit[]
  samplesReceived SampleDistribution[]
}

model Stockist {
  id           Int     @id @default(autoincrement())
  user_id      Int?    @unique
  firm_name    String  @db.NVarChar(255)
  phone        String? @db.NVarChar(50)
  address      String? @db.NVarChar(Max)
  city         String? @db.NVarChar(100)
  lat          Float?
  lng          Float?
  credit_limit Float   @default(0)
  user         Users?  @relation(fields: [user_id], references: [user_id])
}

model Retailer {
  id           Int     @id @default(autoincrement())
  user_id      Int?    @unique
  firm_name    String  @db.NVarChar(255)
  phone        String? @db.NVarChar(50)
  address      String? @db.NVarChar(Max)
  city         String? @db.NVarChar(100)
  lat          Float?
  lng          Float?
  credit_limit Float   @default(0)
  user         Users?  @relation(fields: [user_id], references: [user_id])
}

model MrVisit {
  id            Int      @id @default(autoincrement())
  mr_id         Int
  user_id       Int      // The MR's user account
  doctor_id     Int
  visit_date    DateTime @default(now())
  visit_type    String   @default("FOLLOW_UP") @db.NVarChar(50)
  notes         String?  @db.NVarChar(Max)
  checkin_time  DateTime?
  checkout_time DateTime?
  lat           Float?
  lng           Float?
  samples_given Int      @default(0)
  orders_booked Float    @default(0)

  mr     MedicalRep @relation(fields: [mr_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  user   Users      @relation(fields: [user_id], references: [user_id], onUpdate: NoAction, onDelete: NoAction)
  doctor Doctor     @relation(fields: [doctor_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
}

model MrTarget {
  id           Int      @id @default(autoincrement())
  mr_id        Int
  month        Int
  year         Int
  visit_target Int
  order_target Float
  mr           MedicalRep @relation(fields: [mr_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  items        MrTargetItem[]

  @@unique([mr_id, month, year])
}

model MrTargetItem {
  id         Int      @id @default(autoincrement())
  target_id  Int
  inventory_item_id    Int
  quantity   Int?     @default(0)
  target     MrTarget @relation(fields: [target_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  inventoryItem       InventoryItems @relation(fields: [inventory_item_id], references: [item_id], onUpdate: NoAction, onDelete: NoAction)
}

model SampleDistribution {
  id         Int      @id @default(autoincrement())
  mr_id      Int
  doctor_id  Int
  inventory_item_id    Int
  quantity   Int
  given_date DateTime @default(now())
  mr         MedicalRep @relation(fields: [mr_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  doctor     Doctor     @relation(fields: [doctor_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  inventoryItem       InventoryItems @relation(fields: [inventory_item_id], references: [item_id], onUpdate: NoAction, onDelete: NoAction)
}

model Vendors {
  vendor_id      Int              @id(map: "PK__Vendors__0F7D2B780F151961") @default(autoincrement())
  vendor_name    String           @db.NVarChar(255)
  contact_person String?          @db.NVarChar(255)
  email          String?          @db.NVarChar(255)
  phone          String?          @db.NVarChar(50)
  address        String?          @db.NVarChar(Max)
  currency_id    Int?
  Expenses       Expenses[]
  PurchaseOrders PurchaseOrders[]
  Currencies     Currencies?      @relation(fields: [currency_id], references: [currency_id], onDelete: NoAction, onUpdate: NoAction, map: "FK__Vendors__currenc__21B6055D")
model Expense {
  id          Int      @id @default(autoincrement())
  user_id     Int
  category    String   @db.NVarChar(100)
  amount      Float
  description String?  @db.NVarChar(Max)
  expenseDate DateTime @default(now())
  status      String   @default("SUBMITTED") @db.NVarChar(20)
  approvedBy  Int?
  approvedAt  DateTime?
  user        Users    @relation(fields: [user_id], references: [user_id])
}

model TourPlan {
  id             Int      @id @default(autoincrement())
  mr_id          Int
  planDate       DateTime
  headquarters   String   @db.NVarChar(100)
  plannedVisits  String?  @db.NVarChar(Max) // JSON or comma-separated IDs
  status         String   @default("PLANNED") @db.NVarChar(20)
  mr             MedicalRep @relation(fields: [mr_id], references: [id])
}
