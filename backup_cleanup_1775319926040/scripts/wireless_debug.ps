# VedantaTrade Wireless Debug Deployment Script
# PowerShell script for wireless debugging deployment

param(
    [string]$ProjectPath = ".",
    [int]$DebugPort = 8080,
    [string]$TargetDevice = "",
    [switch]$Verbose = $false,
    [switch]$NoHotReload = $false,
    [switch]$NoDebugLogging = $false
)

# Colors for output
$Colors = @{
    Red = "Red"
    Green = "Green"
    Yellow = "Yellow"
    Blue = "Blue"
    White = "White"
}

# Print colored output
function Write-ColorOutput {
    param([string]$Color, [string]$Message)
    Write-Host $Message -ForegroundColor $Colors[$Color]
}

# Print header
function Write-Header {
    Write-Host ""
    Write-ColorOutput -Color "Blue" "🚀 VedantaTrade Wireless Debug Deployment"
    Write-Host "=========================================="
    Write-Host ""
}

# Print status
function Write-Status {
    param([string]$Status, [string]$Message)
    switch ($Status) {
        "success" { Write-ColorOutput -Color "Green" "✅ $Message" }
        "warning" { Write-ColorOutput -Color "Yellow" "⚠️  $Message" }
        "error"   { Write-ColorOutput -Color "Red" "❌ $Message" }
        "info"    { Write-ColorOutput -Color "Blue" "ℹ️  $Message" }
        default    { Write-Host $Message }
    }
}

# Check prerequisites
function Test-Prerequisites {
    Write-Status -Status "info" -Message "Checking prerequisites..."
    
    # Check Flutter installation
    $flutterPaths = @(
        "$env:LOCALAPPDATA\Pub\Cache\hosted\pub.dev\flutter-3.19.6\flutter",
        "$env:LOCALAPPDATA\Pub\Cache\hosted\pub.dev\flutter-3.19.6\bin\flutter.bat",
        "C:\flutter\bin\flutter.bat",
        "C:\src\flutter\bin\flutter.bat"
    )
    
    $flutterFound = $false
    foreach ($path in $flutterPaths) {
        if (Test-Path $path) {
            $flutterFound = $true
            $env:FLUTTER_PATH = Split-Path $path -Parent
            $env:PATH += ";$env:FLUTTER_PATH"
            Write-Status -Status "success" -Message "Flutter found at: $path"
            break
        }
    }
    
    if (-not $flutterFound) {
        Write-Status -Status "error" -Message "Flutter not found. Please install Flutter SDK"
        Write-Host "Download Flutter from: https://flutter.dev/docs/get-started/install/windows"
        exit 1
    }
    
    # Check Flutter version
    try {
        $flutterVersion = & flutter --version 2>$null
        Write-Status -Status "success" -Message "Flutter version: $flutterVersion"
    } catch {
        Write-Status -Status "warning" -Message "Could not determine Flutter version"
    }
    
    # Check ADB for Android debugging
    try {
        $adbVersion = & adb version 2>$null
        Write-Status -Status "success" -Message "ADB found: $adbVersion"
    } catch {
        Write-Status -Status "warning" -Message "ADB not found - Android debugging may not work"
    }
    
    # Check network connectivity
    try {
        $pingResult = Test-Connection -ComputerName "8.8.8.8" -Count 1 -Quiet
        if ($pingResult) {
            Write-Status -Status "success" -Message "Network connectivity confirmed"
        } else {
            Write-Status -Status "warning" -Message "Network connectivity issues detected"
        }
    } catch {
        Write-Status -Status "warning" -Message "Network check failed"
    }
    
    Write-Host ""
}

# Start wireless server
function Start-WirelessServer {
    Write-Status -Status "info" -Message "Starting wireless server..."
    
    Set-Location $ProjectPath
    
    # Start debug server
    $serverArgs = @(
        "run",
        "--debug",
        "--host=0.0.0.0",
        "--port=$DebugPort",
        "--web-port=$($DebugPort + 1)",
        "--web-hostname=0.0.0.0",
        "--web-port-debug=$($DebugPort + 2)",
        "--web-port-profile=$($DebugPort + 3)",
        "--web-port-observatory=$($DebugPort + 4)"
    )
    
    if ($TargetDevice) {
        $serverArgs += "-d", $TargetDevice
    }
    
    if (-not $NoHotReload) {
        $serverArgs += "--hot"
    }
    
    if ($Verbose) {
        $serverArgs += "--verbose"
    }
    
    Write-Status -Status "info" -Message "Starting Flutter debug server..."
    Write-Status -Status "info" -Message "Server will be available at: http://0.0.0.0:$DebugPort"
    Write-Status -Status "info" -Message "Debug console: http://0.0.0.0:$($DebugPort + 1)"
    Write-Status -Status "info" -Message "Observatory: http://0.0.0.0:$($DebugPort + 4)"
    
    # Start the server
    & flutter @serverArgs
    
    # Wait for server to start
    Start-Sleep -Seconds 5
    
    Write-Status -Status "success" -Message "Wireless server started successfully"
}

# Main execution
function Main {
    Write-Header
    
    # Check prerequisites
    Test-Prerequisites
    
    # Start wireless server
    Start-WirelessServer
    
    Write-Host ""
    Write-Status -Status "info" -Message "🎯 Wireless debugging is now active!"
    Write-Status -Status "info" -Message "💡 Use your browser to debug app wirelessly"
    Write-Status -Status "info" -Message "📱 Connect your mobile device to the same network"
    Write-Status -Status "info" -Message "🌐 Access debug console from any device on the network"
    Write-Host ""
    Write-Status -Status "info" -Message "📡 Debug server: http://0.0.0.0:$DebugPort"
    Write-Status -Status "info" -Message "📱 Debug console: http://localhost:$DebugPort"
    Write-Status -Status "info" -Message "🔍 Observatory: http://localhost:$($DebugPort + 4)"
    Write-Host ""
}

# Handle Ctrl+C
[Console]::TreatControlCAsInput = $true
try {
    Main
} catch {
    Write-Status -Status "error" -Message "❌ Deployment failed: $_"
    exit 1
} finally {
    # Cleanup on exit
    Get-Process -Name "flutter" -ErrorAction SilentlyContinue | Stop-Process -Force
    Write-Status -Status "info" -Message "✅ Wireless debugging stopped"
}

# Export functions for script use
Export-ModuleMember -Function Write-ColorOutput, Write-Status, Test-Prerequisites, Start-WirelessServer
